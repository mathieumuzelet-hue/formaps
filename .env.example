# ── Application (runtime) ──────────────────────────────────────────────
# En local : pointez vers la base de dev (docker postgres sur :5433).
# En prod (docker-compose) : DATABASE_URL est dérivée des POSTGRES_* ci-dessous
# et n'a pas besoin d'être définie à la main.
DATABASE_URL=postgres://cockpit:cockpit@localhost:5433/cockpit

# Secret de session Auth.js. Générer avec : openssl rand -base64 32
AUTH_SECRET=

# Conteneur Dify séparé (URL réseau interne du VPS en prod).
DIFY_API_URL=
DIFY_API_KEY=

# ── Bootstrap admin (au démarrage, idempotent) ─────────────────────────
# Si ces deux variables sont définies, le conteneur crée (ou met à jour) un
# compte admin à chaque boot. L'admin n'est rattaché à aucun magasin.
# Laisser vide pour ne pas créer de compte automatiquement.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FIRSTNAME=Admin

# ── Déploiement (docker-compose / Dokploy) ─────────────────────────────
# Domaine public servi par Traefik. Doit aussi être déclaré dans l'UI Dokploy.
DOMAIN=cockpit.example.com

# Identifiants de la base Postgres dédiée (service `db`).
POSTGRES_USER=cockpit
POSTGRES_PASSWORD=change-me
POSTGRES_DB=cockpit
